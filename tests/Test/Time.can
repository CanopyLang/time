module Test.Time exposing (main, tests)

import Basics exposing (..)
import List
import String
import Time exposing (..)
import Test exposing (..)
import Expect


main : Test
main =
    tests


tests : Test
tests =
    describe "Time Tests"
        [ posixConversionTests
        , utcExtractionTests
        , monthTests
        , weekdayTests
        , customZoneTests
        , epochBoundaryTests
        , halfHourOffsetTests
        , zoneNameTests
        , dayRolloverTests
        , preEpochTests
        , monthCorrectnessTests
        , weekdayCorrectnessTests
        , subscriptionTests
        , millenniumBoundaryTests
        , multiEraZoneTests
        ]



-- POSIX CONVERSION


posixConversionTests : Test
posixConversionTests =
    describe "Posix Conversion"
        [ test "posixToMillis and millisToPosix round-trip" <|
            \() -> Expect.equal 0 (posixToMillis (millisToPosix 0))
        , test "round-trip with positive value" <|
            \() -> Expect.equal 1234567890 (posixToMillis (millisToPosix 1234567890))
        , test "round-trip with large value" <|
            \() -> Expect.equal 1709222400000 (posixToMillis (millisToPosix 1709222400000))
        , test "epoch is zero" <|
            \() -> Expect.equal 0 (posixToMillis (millisToPosix 0))
        ]



-- UTC EXTRACTION
-- Reference: 2024-02-29 15:30:45.123 UTC = 1709220645123 ms since epoch


utcExtractionTests : Test
utcExtractionTests =
    let
        -- 2024-02-29 15:30:45.123 UTC
        time = millisToPosix 1709220645123
    in
    describe "UTC Time Extraction"
        [ test "toYear UTC" <|
            \() -> Expect.equal 2024 (toYear utc time)
        , test "toMonth UTC" <|
            \() -> Expect.equal Feb (toMonth utc time)
        , test "toDay UTC" <|
            \() -> Expect.equal 29 (toDay utc time)
        , test "toWeekday UTC" <|
            \() -> Expect.equal Thu (toWeekday utc time)
        , test "toHour UTC" <|
            \() -> Expect.equal 15 (toHour utc time)
        , test "toMinute UTC" <|
            \() -> Expect.equal 30 (toMinute utc time)
        , test "toSecond UTC" <|
            \() -> Expect.equal 45 (toSecond utc time)
        , test "toMillis UTC" <|
            \() -> Expect.equal 123 (toMillis utc time)
        , describe "epoch extraction"
            [ test "epoch year" <|
                \() -> Expect.equal 1970 (toYear utc (millisToPosix 0))
            , test "epoch month" <|
                \() -> Expect.equal Jan (toMonth utc (millisToPosix 0))
            , test "epoch day" <|
                \() -> Expect.equal 1 (toDay utc (millisToPosix 0))
            , test "epoch weekday" <|
                \() -> Expect.equal Thu (toWeekday utc (millisToPosix 0))
            , test "epoch hour" <|
                \() -> Expect.equal 0 (toHour utc (millisToPosix 0))
            ]
        , describe "end of year"
            (let
                -- 2023-12-31 23:59:59.999 UTC
                endOfYear = millisToPosix 1704067199999
             in
             [ test "year" <|
                \() -> Expect.equal 2023 (toYear utc endOfYear)
             , test "month" <|
                \() -> Expect.equal Dec (toMonth utc endOfYear)
             , test "day" <|
                \() -> Expect.equal 31 (toDay utc endOfYear)
             , test "hour" <|
                \() -> Expect.equal 23 (toHour utc endOfYear)
             , test "minute" <|
                \() -> Expect.equal 59 (toMinute utc endOfYear)
             , test "second" <|
                \() -> Expect.equal 59 (toSecond utc endOfYear)
             ]
            )
        ]



-- MONTH AND WEEKDAY


monthTests : Test
monthTests =
    describe "Month type coverage"
        [ test "Jan through Dec are distinct" <|
            \() ->
                let
                    months = [Jan, Feb, Mar, Apr, May, Jun, Jul, Aug, Sep, Oct, Nov, Dec]
                in
                Expect.equal 12 (List.length months)
        , test "each month extracted from a known date is correct" <|
            \() ->
                -- Verify each month maps to its own value by extracting from known timestamps
                -- 2024-01-15, 2024-02-15, ... 2024-12-15 (all at 12:00 UTC)
                let
                    monthsFromDates =
                        List.map (\t -> toMonth utc (millisToPosix t))
                            [ 1705320000000  -- 2024-01-15 12:00 UTC
                            , 1707998400000  -- 2024-02-15 12:00 UTC
                            , 1710504000000  -- 2024-03-15 12:00 UTC
                            , 1713182400000  -- 2024-04-15 12:00 UTC
                            , 1715774400000  -- 2024-05-15 12:00 UTC
                            , 1718452800000  -- 2024-06-15 12:00 UTC
                            , 1721044800000  -- 2024-07-15 12:00 UTC
                            , 1723723200000  -- 2024-08-15 12:00 UTC
                            , 1726401600000  -- 2024-09-15 12:00 UTC
                            , 1728993600000  -- 2024-10-15 12:00 UTC
                            , 1731672000000  -- 2024-11-15 12:00 UTC
                            , 1734264000000  -- 2024-12-15 12:00 UTC
                            ]
                in
                Expect.equal
                    [Jan, Feb, Mar, Apr, May, Jun, Jul, Aug, Sep, Oct, Nov, Dec]
                    monthsFromDates
        ]


weekdayTests : Test
weekdayTests =
    describe "Weekday type coverage"
        [ test "Mon through Sun are distinct" <|
            \() ->
                let
                    days = [Mon, Tue, Wed, Thu, Fri, Sat, Sun]
                in
                Expect.equal 7 (List.length days)
        , test "each weekday extracted from consecutive days is correct" <|
            \() ->
                -- 2024-01-01 (Mon) through 2024-01-07 (Sun), all at 12:00 UTC
                let
                    weekdaysFromDates =
                        List.map (\t -> toWeekday utc (millisToPosix t))
                            [ 1704110400000  -- 2024-01-01 12:00 UTC (Mon)
                            , 1704196800000  -- 2024-01-02 12:00 UTC (Tue)
                            , 1704283200000  -- 2024-01-03 12:00 UTC (Wed)
                            , 1704369600000  -- 2024-01-04 12:00 UTC (Thu)
                            , 1704456000000  -- 2024-01-05 12:00 UTC (Fri)
                            , 1704542400000  -- 2024-01-06 12:00 UTC (Sat)
                            , 1704628800000  -- 2024-01-07 12:00 UTC (Sun)
                            ]
                in
                Expect.equal
                    [Mon, Tue, Wed, Thu, Fri, Sat, Sun]
                    weekdaysFromDates
        , describe "known weekdays"
            [ test "2024-01-01 is Monday" <|
                \() -> Expect.equal Mon (toWeekday utc (millisToPosix 1704067200000))
            , test "2024-01-06 is Saturday" <|
                \() -> Expect.equal Sat (toWeekday utc (millisToPosix 1704499200000))
            , test "2024-01-07 is Sunday" <|
                \() -> Expect.equal Sun (toWeekday utc (millisToPosix 1704585600000))
            ]
        ]



-- EPOCH BOUNDARY


epochBoundaryTests : Test
epochBoundaryTests =
    describe "Epoch boundary"
        [ test "timestamp 0 year is 1970" <|
            \() -> Expect.equal 1970 (toYear utc (millisToPosix 0))
        , test "timestamp 0 month is Jan" <|
            \() -> Expect.equal Jan (toMonth utc (millisToPosix 0))
        , test "timestamp 0 day is 1" <|
            \() -> Expect.equal 1 (toDay utc (millisToPosix 0))
        , test "timestamp 0 weekday is Thu" <|
            \() -> Expect.equal Thu (toWeekday utc (millisToPosix 0))
        , test "timestamp 0 hour is 0" <|
            \() -> Expect.equal 0 (toHour utc (millisToPosix 0))
        , test "timestamp 0 minute is 0" <|
            \() -> Expect.equal 0 (toMinute utc (millisToPosix 0))
        , test "timestamp 0 second is 0" <|
            \() -> Expect.equal 0 (toSecond utc (millisToPosix 0))
        , test "timestamp 0 millis is 0" <|
            \() -> Expect.equal 0 (toMillis utc (millisToPosix 0))
        , test "timestamp 1 millisecond after epoch" <|
            \() ->
                let
                    t = millisToPosix 1
                in
                Expect.equal (0, 0, 1) (toHour utc t, toMinute utc t, toMillis utc t)
        , test "one second after epoch" <|
            \() ->
                let
                    t = millisToPosix 1000
                in
                Expect.equal (0, 0, 1) (toHour utc t, toMinute utc t, toSecond utc t)
        ]



-- CUSTOM ZONE


customZoneTests : Test
customZoneTests =
    let
        -- UTC+5:30 (India Standard Time)
        ist = customZone 330 []

        -- 2024-02-29 15:30:45 UTC = 2024-02-29 21:00:45 IST
        time = millisToPosix 1709220645000
    in
    describe "Custom Zone"
        [ test "IST hour (UTC+5:30)" <|
            \() -> Expect.equal 21 (toHour ist time)
        , test "IST minute" <|
            \() -> Expect.equal 0 (toMinute ist time)
        , describe "negative offset"
            (let
                -- UTC-5 (Eastern Standard Time)
                est = customZone -300 []
             in
             [ test "EST hour" <|
                \() -> Expect.equal 10 (toHour est time)
             , test "EST minute" <|
                \() -> Expect.equal 30 (toMinute est time)
             ]
            )
        , describe "non-empty eras (DST-like transitions)"
            (let
                -- Zone that switches offset at a given time:
                -- Before era start (minute 28440960 = 2024-02-01 00:00 UTC): default offset +60 (CET)
                -- After era start: offset +120 (CEST, summer time)
                dstZone = customZone 60
                    [ { start = 28440960, offset = 120 } ]
                -- A time well after the era start: 2024-03-31 12:00 UTC = minute 28524000
                summerTime = millisToPosix 1711886400000
                -- A time before the era start: 2024-01-15 12:00 UTC = minute 28417920
                winterTime = millisToPosix 1705320000000
             in
             [ test "summer time uses era offset (+2h)" <|
                \() -> Expect.equal 14 (toHour dstZone summerTime)
             , test "winter time uses default offset (+1h)" <|
                \() -> Expect.equal 13 (toHour dstZone winterTime)
             ]
            )
        ]



-- HALF-HOUR OFFSET ZONE


halfHourOffsetTests : Test
halfHourOffsetTests =
    describe "Half-hour offset zones"
        [ describe "UTC+5:45 (Nepal Time)"
            (let
                -- 345 minutes = 5 hours 45 minutes
                npt = customZone 345 []
                -- 2024-01-15 12:00:00 UTC
                time = millisToPosix 1705320000000
             in
             [ test "NPT hour is 17" <|
                \() -> Expect.equal 17 (toHour npt time)
             , test "NPT minute is 45" <|
                \() -> Expect.equal 45 (toMinute npt time)
             ]
            )
        , describe "UTC+9:30 (Australian Central Standard Time)"
            (let
                acst = customZone 570 []
                -- 2024-01-15 12:00:00 UTC
                time = millisToPosix 1705320000000
             in
             [ test "ACST hour is 21" <|
                \() -> Expect.equal 21 (toHour acst time)
             , test "ACST minute is 30" <|
                \() -> Expect.equal 30 (toMinute acst time)
             ]
            )
        ]



-- ZONE NAME


zoneNameTests : Test
zoneNameTests =
    describe "ZoneName type"
        [ test "Name constructor wraps a string" <|
            \() ->
                let
                    zoneName = Name "Europe/Moscow"
                in
                case zoneName of
                    Name n ->
                        Expect.equal "Europe/Moscow" n
                    Offset _ ->
                        Expect.fail "Expected Name, got Offset"
        , test "Offset constructor wraps an int" <|
            \() ->
                let
                    zoneName = Offset 180
                in
                case zoneName of
                    Name _ ->
                        Expect.fail "Expected Offset, got Name"
                    Offset o ->
                        Expect.equal 180 o
        , test "Name and Offset are distinct" <|
            \() ->
                let
                    name = Name "UTC"
                    offset = Offset 0
                in
                Expect.notEqual (zoneNameToString name) (zoneNameToString offset)
        ]


zoneNameToString : ZoneName -> String
zoneNameToString zn =
    case zn of
        Name n -> "Name:" ++ n
        Offset o -> "Offset:" ++ String.fromInt o



-- DAY ROLLOVER


dayRolloverTests : Test
dayRolloverTests =
    describe "Day rollover with positive offset"
        [ test "23:00 UTC + offset 120 rolls day to 16" <|
            \() ->
                let
                    -- 2024-01-15 23:00:00 UTC
                    lateNight = millisToPosix 1705359600000
                    plus2 = customZone 120 []
                in
                Expect.equal 16 (toDay plus2 lateNight)
        , test "23:00 UTC + offset 120 rolls hour to 1" <|
            \() ->
                let
                    lateNight = millisToPosix 1705359600000
                    plus2 = customZone 120 []
                in
                Expect.equal 1 (toHour plus2 lateNight)
        , test "23:30 UTC + offset 330 rolls day to 16" <|
            \() ->
                let
                    -- 2024-01-15 23:30:00 UTC
                    lateNight = millisToPosix 1705361400000
                    ist = customZone 330 []
                in
                Expect.equal 16 (toDay ist lateNight)
        , test "23:30 UTC + offset 330 rolls hour to 5" <|
            \() ->
                let
                    lateNight = millisToPosix 1705361400000
                    ist = customZone 330 []
                in
                Expect.equal 5 (toHour ist lateNight)
        , test "midnight boundary: 23:59 UTC + offset 1 rolls day to 16" <|
            \() ->
                let
                    -- 2024-01-15 23:59:00 UTC
                    almostMidnight = millisToPosix 1705363140000
                    plus1min = customZone 1 []
                in
                Expect.equal 16 (toDay plus1min almostMidnight)
        , test "midnight boundary: 23:59 UTC + offset 1 rolls hour to 0" <|
            \() ->
                let
                    almostMidnight = millisToPosix 1705363140000
                    plus1min = customZone 1 []
                in
                Expect.equal 0 (toHour plus1min almostMidnight)
        , test "negative offset rolls day backward" <|
            \() ->
                let
                    -- 2024-01-16 00:30:00 UTC
                    earlyMorning = millisToPosix 1705365000000
                    minus2 = customZone -120 []
                in
                Expect.equal 15 (toDay minus2 earlyMorning)
        , test "negative offset rolls hour backward" <|
            \() ->
                let
                    earlyMorning = millisToPosix 1705365000000
                    minus2 = customZone -120 []
                in
                Expect.equal 22 (toHour minus2 earlyMorning)
        ]



-- PRE-EPOCH DATES


preEpochTests : Test
preEpochTests =
    describe "Pre-epoch dates (negative milliseconds)"
        [ test "1960-06-15 12:00 UTC year is 1960" <|
            \() ->
                -- 1960-06-15 12:00:00 UTC = -301233600000 ms
                Expect.equal 1960 (toYear utc (millisToPosix -301233600000))
        , test "1960-06-15 12:00 UTC month is Jun" <|
            \() ->
                Expect.equal Jun (toMonth utc (millisToPosix -301233600000))
        , test "1960-06-15 12:00 UTC day is 15" <|
            \() ->
                Expect.equal 15 (toDay utc (millisToPosix -301233600000))
        , test "1960-06-15 12:00 UTC hour is 12" <|
            \() ->
                Expect.equal 12 (toHour utc (millisToPosix -301233600000))
        , test "1969-12-31 23:59:59 UTC year" <|
            \() ->
                Expect.equal 1969 (toYear utc (millisToPosix -1))
        , test "1969-12-31 23:59:59 UTC month" <|
            \() ->
                Expect.equal Dec (toMonth utc (millisToPosix -1))
        , test "1969-12-31 23:59:59 UTC day" <|
            \() ->
                Expect.equal 31 (toDay utc (millisToPosix -1))
        , test "1969-12-31 23:59:59 UTC time" <|
            \() ->
                Expect.equal
                    ( 23, 59, 59 )
                    ( toHour utc (millisToPosix -1)
                    , toMinute utc (millisToPosix -1)
                    , toSecond utc (millisToPosix -1)
                    )
        , test "negative millis round-trip" <|
            \() ->
                Expect.equal -301233600000 (posixToMillis (millisToPosix -301233600000))
        , test "pre-epoch with positive timezone offset year" <|
            \() ->
                let
                    t = millisToPosix -3600000
                    plus2 = customZone 120 []
                in
                Expect.equal 1970 (toYear plus2 t)
        , test "pre-epoch with positive timezone offset date" <|
            \() ->
                let
                    t = millisToPosix -3600000
                    plus2 = customZone 120 []
                in
                Expect.equal
                    ( Jan, 1, 1 )
                    ( toMonth plus2 t, toDay plus2 t, toHour plus2 t )
        , test "1900-01-01 12:00 UTC year and month" <|
            \() ->
                let
                    t = millisToPosix -2208945600000
                in
                Expect.equal ( 1900, Jan ) ( toYear utc t, toMonth utc t )
        , test "1900-01-01 12:00 UTC day and hour" <|
            \() ->
                let
                    t = millisToPosix -2208945600000
                in
                Expect.equal ( 1, 12 ) ( toDay utc t, toHour utc t )
        ]



-- MONTH CORRECTNESS


monthCorrectnessTests : Test
monthCorrectnessTests =
    describe "Month correctness (specific known dates)"
        [ test "2000-03-01 is Mar (leap year boundary)" <|
            \() ->
                -- 2000-03-01 00:00:00 UTC = 951868800000 ms
                Expect.equal Mar (toMonth utc (millisToPosix 951868800000))
        , test "2000-02-29 exists (leap year)" <|
            \() ->
                -- 2000-02-29 12:00:00 UTC = 951825600000 ms
                Expect.equal
                    ( Feb, 29 )
                    ( toMonth utc (millisToPosix 951825600000)
                    , toDay utc (millisToPosix 951825600000)
                    )
        , test "1900-02-28 is last day of Feb (1900 is not a leap year)" <|
            \() ->
                -- 1900-02-28 12:00:00 UTC = -2203934400000 ms
                Expect.equal
                    ( Feb, 28 )
                    ( toMonth utc (millisToPosix -2203934400000)
                    , toDay utc (millisToPosix -2203934400000)
                    )
        , test "1900-03-01 follows Feb 28 (no Feb 29 in 1900)" <|
            \() ->
                -- 1900-03-01 12:00:00 UTC = -2203848000000 ms
                Expect.equal
                    ( Mar, 1 )
                    ( toMonth utc (millisToPosix -2203848000000)
                    , toDay utc (millisToPosix -2203848000000)
                    )
        , test "2024-12-31 is Dec 31" <|
            \() ->
                -- 2024-12-31 12:00:00 UTC = 1735646400000 ms
                Expect.equal
                    ( Dec, 31 )
                    ( toMonth utc (millisToPosix 1735646400000)
                    , toDay utc (millisToPosix 1735646400000)
                    )
        ]



-- WEEKDAY CORRECTNESS


weekdayCorrectnessTests : Test
weekdayCorrectnessTests =
    describe "Weekday correctness (specific known dates)"
        [ test "1970-01-01 (epoch) is Thursday" <|
            \() ->
                Expect.equal Thu (toWeekday utc (millisToPosix 0))
        , test "2000-01-01 is Saturday" <|
            \() ->
                -- 2000-01-01 12:00:00 UTC = 946728000000 ms
                Expect.equal Sat (toWeekday utc (millisToPosix 946728000000))
        , test "1969-12-31 is Wednesday" <|
            \() ->
                -- 1969-12-31 12:00:00 UTC = -43200000 ms
                Expect.equal Wed (toWeekday utc (millisToPosix -43200000))
        , test "2024-02-29 (leap day) is Thursday" <|
            \() ->
                -- 2024-02-29 12:00:00 UTC = 1709208000000 ms
                Expect.equal Thu (toWeekday utc (millisToPosix 1709208000000))
        , test "2025-01-01 is Wednesday" <|
            \() ->
                -- 2025-01-01 12:00:00 UTC = 1735732800000 ms
                Expect.equal Wed (toWeekday utc (millisToPosix 1735732800000))
        ]



-- SUBSCRIPTION


subscriptionTests : Test
subscriptionTests =
    describe "Subscription"
        [ test "every produces a Sub" <|
            \() ->
                let
                    sub = every 1000 posixToMillis
                in
                -- We cannot inspect the Sub, but we can verify it was constructed
                -- without error by checking a known value alongside it
                Expect.equal 1000 1000
        ]



-- MILLENNIUM BOUNDARY


millenniumBoundaryTests : Test
millenniumBoundaryTests =
    describe "Millennium boundary (Y2K)"
        [ test "1999-12-31 23:59:59 UTC year" <|
            \() ->
                -- 1999-12-31 23:59:59.999 UTC = 946684799999 ms
                Expect.equal 1999 (toYear utc (millisToPosix 946684799999))
        , test "2000-01-01 00:00:00 UTC year" <|
            \() ->
                -- 2000-01-01 00:00:00.000 UTC = 946684800000 ms
                Expect.equal 2000 (toYear utc (millisToPosix 946684800000))
        , test "2000-01-01 00:00:00 UTC month" <|
            \() ->
                Expect.equal Jan (toMonth utc (millisToPosix 946684800000))
        , test "2000-01-01 00:00:00 UTC day" <|
            \() ->
                Expect.equal 1 (toDay utc (millisToPosix 946684800000))
        , test "millennium in negative offset zone sees 1999" <|
            \() ->
                let
                    minus1 = customZone -60 []
                in
                Expect.equal 1999 (toYear minus1 (millisToPosix 946684800000))
        , test "millennium in positive offset zone sees 2000" <|
            \() ->
                let
                    plus1 = customZone 60 []
                in
                Expect.equal 2000 (toYear plus1 (millisToPosix 946684800000))
        ]



-- MULTI-ERA ZONE


multiEraZoneTests : Test
multiEraZoneTests =
    describe "Multi-era zone (multiple DST transitions)"
        [ describe "two era transitions"
            (let
                -- Zone with two era transitions:
                -- Era 2: starts at minute 28524000 (2024-03-31 00:00 UTC), offset +120 (CEST)
                -- Era 1: starts at minute 28908000 (2024-10-27 00:00 UTC), offset +60 (CET)
                -- Default offset: +60 (CET, for times before first era)
                twoEraZone = customZone 60
                    [ { start = 28908000, offset = 60 }
                    , { start = 28524000, offset = 120 }
                    ]
                -- Before both eras: 2024-01-15 12:00 UTC
                beforeBoth = millisToPosix 1705320000000
                -- Between eras: 2024-06-15 12:00 UTC = minute 28668720
                betweenEras = millisToPosix 1718452800000
                -- After both eras: 2025-01-17 12:00 UTC (minute 28951200, well after 28908000)
                afterBoth = millisToPosix 1737115200000
             in
             [ test "before both eras uses default offset (+1h)" <|
                \() -> Expect.equal 13 (toHour twoEraZone beforeBoth)
             , test "between eras uses second era offset (+2h)" <|
                \() -> Expect.equal 14 (toHour twoEraZone betweenEras)
             , test "after both eras uses first era offset (+1h)" <|
                \() -> Expect.equal 13 (toHour twoEraZone afterBoth)
             , test "day changes with era offset" <|
                \() ->
                    let
                        -- 2024-06-15 23:30 UTC -- with +2h offset becomes 2024-06-16 01:30
                        lateInSummer = millisToPosix 1718494200000
                    in
                    Expect.equal 16 (toDay twoEraZone lateInSummer)
             , test "month changes with era offset" <|
                \() ->
                    let
                        -- 2024-06-30 23:00 UTC -- with +2h offset becomes 2024-07-01 01:00
                        endOfJuneSummer = millisToPosix 1719788400000
                    in
                    Expect.equal Jul (toMonth twoEraZone endOfJuneSummer)
             , test "year changes with era offset" <|
                \() ->
                    let
                        -- Use a zone where the era makes the year roll over
                        -- 2024-12-31 23:30 UTC with +1h (CET, after second era) -> 2025-01-01 00:30
                        newYearsEve = millisToPosix 1735689000000
                    in
                    Expect.equal 2025 (toYear twoEraZone newYearsEve)
             ]
            )
        , describe "weekday with offset zones"
            [ test "weekday rolls forward with positive offset" <|
                \() ->
                    let
                        -- 2024-01-07 (Sunday) 23:00 UTC + offset 120 = 2024-01-08 (Monday) 01:00
                        sundayLate = millisToPosix 1704668400000
                        plus2 = customZone 120 []
                    in
                    Expect.equal Mon (toWeekday plus2 sundayLate)
            , test "weekday rolls backward with negative offset" <|
                \() ->
                    let
                        -- 2024-01-08 (Monday) 01:00 UTC - offset 120 = 2024-01-07 (Sunday) 23:00
                        mondayEarly = millisToPosix 1704675600000
                        minus2 = customZone -120 []
                    in
                    Expect.equal Sun (toWeekday minus2 mondayEarly)
            ]
        , describe "second and millis are zone-independent"
            [ test "toSecond same in different zones" <|
                \() ->
                    let
                        t = millisToPosix 1709220645123
                        ist = customZone 330 []
                        est = customZone -300 []
                    in
                    Expect.equal
                        (toSecond utc t, toSecond ist t, toSecond est t)
                        (45, 45, 45)
            , test "toMillis same in different zones" <|
                \() ->
                    let
                        t = millisToPosix 1709220645123
                        ist = customZone 330 []
                        est = customZone -300 []
                    in
                    Expect.equal
                        (toMillis utc t, toMillis ist t, toMillis est t)
                        (123, 123, 123)
            ]
        ]
